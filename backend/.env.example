# ─────────────────────────────────────────────────────────────
# Copy this file to ".env" and replace the placeholder values
# with your real API keys before running the server.
# ─────────────────────────────────────────────────────────────

# Get your free key at https://newsapi.org/register
NEWS_API_KEY=YOUR_NEWSAPI_KEY_HERE

# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Port the Express server will listen on
PORT=5000

# Supabase — get these from your project: Settings → API
# Project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=YOUR_SUPABASE_URL_HERE
# service_role secret key (never expose this on the client)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# Your deployed frontend URL (e.g. https://your-app.vercel.app)
FRONTEND_URL=YOUR_FRONTEND_URL_HERE
